#!/bin/bash

# ABRIR SESIÓN RDP

# Valores por defecto
IP="192.168.0.252"
USER=""
PASSWORD=""
FULLSCREEN=true

# Distribución de teclado. Se usan dos valores que deben ser coherentes entre sí:
#   KBD_LAYOUT  -> código de layout para xfreerdp (/kbd)
#   XKB_LAYOUT  -> layout del teclado del host (setxkbmap)
#
# Combinaciones más comunes en Argentina:
#   Español (España):        KBD_LAYOUT="0x0000040A"  XKB_LAYOUT="es"
#   Español (Latinoamérica): KBD_LAYOUT="0x0000080A"  XKB_LAYOUT="latam"
#   Español (Argentina):     KBD_LAYOUT="0x00002C0A"  XKB_LAYOUT="latam"
#   Inglés (EE.UU.):         KBD_LAYOUT="0x00000409"  XKB_LAYOUT="us"
KBD_LAYOUT="0x0000040A"
XKB_LAYOUT="es"

# Comprobar si existe el archivo de configuración global
if [ -f "/etc/elatril-utils/rdp-session.config" ]; then
    . /etc/elatril-utils/rdp-session.config
fi

# Comprobar si existe un archivo de configuración de usuario
if [ -f "$HOME/elatril-utils/rdp-session/rdp-session.config" ]; then
    . "$HOME/elatril-utils/rdp-session/rdp-session.config"
fi

# Detectar el binario de FreeRDP disponible (v3 tiene prioridad).
# FreeRDP 3 (freerdp3-x11) usa el binario 'xfreerdp3' y exige el prefijo
# 'layout:' en /kbd; FreeRDP 2 (freerdp2-x11) usa 'xfreerdp' y el /kbd simple.
if command -v xfreerdp3 >/dev/null 2>&1; then
    FREERDP_BIN="xfreerdp3"
    KBD_ARG="/kbd:layout:$KBD_LAYOUT"
elif command -v xfreerdp >/dev/null 2>&1; then
    FREERDP_BIN="xfreerdp"
    KBD_ARG="/kbd:$KBD_LAYOUT"
else
    echo "Error: no se encontró 'xfreerdp' ni 'xfreerdp3'." >&2
    echo "Instalá el paquete freerdp2-x11 o freerdp3-x11." >&2
    exit 1
fi

# Construir argumentos de xfreerdp dinámicamente
ARGS="/v:$IP $KBD_ARG"

if [ "$FULLSCREEN" = true ]; then
    ARGS="$ARGS /f"
else 
    ARGS="$ARGS /workarea"
fi

if [ -n "$USER" ]; then
    ARGS="$ARGS /u:$USER"
fi

if [ -n "$PASSWORD" ]; then
    ARGS="$ARGS /p:$PASSWORD"
fi

# Fijar el teclado del host para que coincida con la sesión RDP
setxkbmap "$XKB_LAYOUT"

# Ejecutar con el binario detectado y los argumentos construidos
"$FREERDP_BIN" $ARGS
